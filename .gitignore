# =============================================================================
# example-org/ci-components — shared GitLab CI/CD components hub (.gitignore)
# =============================================================================
# This repo hosts the shared CI/CD components, the ci-base image Dockerfile,
# and the shared publish/sanitize Python tooling (under .ci/scripts/).
# =============================================================================

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# IDE & editor files
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.code-workspace
.idea/
*.iml
*.swp
*.swo
*~
.cursor/

# -----------------------------------------------------------------------------
# Secrets & keys (never commit — components read them from CI/CD variables)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.p12
*.pfx
id_*
!id_*.example
.kryptos_token

# -----------------------------------------------------------------------------
# CI artifacts (pipeline reports + local run output)
# -----------------------------------------------------------------------------
image-ref.txt
gl-code-quality-report.json
gl-secret-detection-report.json
*.sarif
child-pipeline.yml

# -----------------------------------------------------------------------------
# Python test artifacts (pytest, coverage) for .ci/scripts/
# -----------------------------------------------------------------------------
__pycache__/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# -----------------------------------------------------------------------------
# Local caches & temp files
# -----------------------------------------------------------------------------
.cache/
*.bak
*.old
*.orig
*.tmp
*.log
